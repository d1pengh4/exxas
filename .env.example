# ── LLM Provider ──────────────────────────────────────────
# "claude" | "ollama" | "openai" | "groq"
LLM_PROVIDER=groq
LLM_MODEL=claude-sonnet-4-6

# Anthropic (claude 사용 시)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (openai 사용 시)
OPENAI_API_KEY=your_openai_api_key_here

# Groq (현재 활성, 무료)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=qwen/qwen3-32b

# Ollama (로컬 LLM 사용 시)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:7b

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://exxas:exxas_dev@localhost:5432/exxas
REDIS_URL=redis://localhost:6379/0

# ── Milvus (벡터 DB) ───────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ── Neo4j (지식 그래프) ────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=exxas_dev

# ── 지도 API ──────────────────────────────────────────────
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
KAKAO_API_KEY=your_kakao_api_key
KAKAO_ACCESS_TOKEN=                 # Kakao OAuth Bearer (KakaoAK 403 시 폴백)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── 한국 전용 API ─────────────────────────────────────────
JUSO_API_KEY=your_juso_api_key               # 행정안전부 도로명주소 API
PUBLIC_DATA_API_KEY=your_public_data_api_key  # 공공데이터포털
CLOVA_OCR_API_KEY=                           # 네이버 CLOVA OCR Secret Key (선택)
CLOVA_OCR_API_URL=                           # CLOVA OCR Invoke URL (선택)

# ── OSINT API ─────────────────────────────────────────────
FLICKR_API_KEY=your_flickr_api_key
SERP_API_KEY=your_serp_api_key     # Google 역이미지 검색 (stage2)
SERPAPI_KEY=                        # SerpAPI 키 (web_search 도구용, 없으면 DuckDuckGo)
BING_SEARCH_API_KEY=                # Bing Visual Search (stage2)
BRAVE_SEARCH_API_KEY=               # Brave Search API (DDG 차단 시 폴백)
MAPILLARY_TOKEN=                    # Mapillary API 토큰 (street_view_fetch 도구용)
HF_TOKEN=                           # HuggingFace token (private 모델 접근 시)

# ── 위성/기상 ─────────────────────────────────────────────
NASA_API_KEY=DEMO_KEY  # NASA 무료 키
OPEN_METEO_API_URL=https://api.open-meteo.com/v1

# ── 보안 ──────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_secret_key_in_production
ADMIN_SECRET_KEY=change_this_admin_key_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── 스토리지 ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ── 분석 설정 ─────────────────────────────────────────────
MAX_INVESTIGATION_STEPS=20
CONFIDENCE_THRESHOLD_HIGH=0.95
CONFIDENCE_THRESHOLD_MEDIUM=0.70
CONFIDENCE_THRESHOLD_LOW=0.30

# ── 환경 ──────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
